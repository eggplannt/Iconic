{
  "expo": {
    "name": "iconic",
    "slug": "iconic",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "iconic",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ff6b00"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "plugins": ["expo-web-browser"],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "03a59482-934d-41bc-8319-c161430428e0"
      }
    },
    "owner": "eggplannt"
  }
}
